enum UserStatus {
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")
  DELETED   @map("deleted")

  @@map("user_status")
}

enum OrganizationStatus {
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")
  CLOSED    @map("closed")

  @@map("organization_status")
}

enum OrganizationRole {
  OWNER  @map("owner")
  ADMIN  @map("admin")
  EDITOR @map("editor")
  VIEWER @map("viewer")

  @@map("organization_role")
}

enum IdentityProvider {
  GOOGLE @map("google")

  @@map("identity_provider")
}

model User {
  id          String     @id @db.Uuid
  email       String     @unique(map: "users_email_key") @db.VarChar(320)
  displayName String?    @map("display_name") @db.VarChar(160)
  avatarUrl   String?    @map("avatar_url") @db.Text
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)

  memberships     OrganizationMembership[]
  auditLogs       AuditLog[]               @relation("AuditActor")
  identities      ExternalIdentity[]
  sessions        AuthSession[]
  projectsCreated Project[]                @relation("ProjectCreator")
  videosCreated   Video[]                  @relation("VideoCreator")

  @@index([status], map: "users_status_idx")
  @@map("users")
}

model Organization {
  id          String             @id @db.Uuid
  slug        String             @unique(map: "organizations_slug_key") @db.VarChar(63)
  displayName String             @map("display_name") @db.VarChar(160)
  status      OrganizationStatus @default(ACTIVE)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?          @map("deleted_at") @db.Timestamptz(6)

  memberships      OrganizationMembership[]
  auditLogs        AuditLog[]
  outboxEvents     OutboxEvent[]
  projects         Project[]
  videos           Video[]
  multipartUploads MultipartUpload[]
  authSessions     AuthSession[]

  @@index([status], map: "organizations_status_idx")
  @@map("organizations")
}

model ExternalIdentity {
  id              String           @id @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  provider        IdentityProvider
  providerSubject String           @map("provider_subject") @db.VarChar(191)
  emailAtLink     String           @map("email_at_link") @db.VarChar(320)
  lastLoginAt     DateTime         @default(now()) @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerSubject], map: "external_identities_provider_subject_key")
  @@index([userId], map: "external_identities_user_id_idx")
  @@map("external_identities")
}

model OAuthAuthorization {
  id                     String           @id @db.Uuid
  provider               IdentityProvider
  stateHash              String           @unique(map: "oauth_authorizations_state_hash_key") @map("state_hash") @db.Char(64)
  nonceHash              String           @map("nonce_hash") @db.Char(64)
  codeVerifierCiphertext String           @map("code_verifier_ciphertext") @db.Text
  redirectPath           String           @map("redirect_path") @db.VarChar(512)
  expiresAt              DateTime         @map("expires_at") @db.Timestamptz(6)
  consumedAt             DateTime?        @map("consumed_at") @db.Timestamptz(6)
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "oauth_authorizations_expires_at_idx")
  @@map("oauth_authorizations")
}

model AuthSession {
  id                  String    @id @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  familyId            String    @map("family_id") @db.Uuid
  refreshTokenHash    String    @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash") @db.Char(64)
  userAgentHash       String?   @map("user_agent_hash") @db.Char(64)
  ipAddressHash       String?   @map("ip_address_hash") @db.Char(64)
  replacedBySessionId String?   @unique(map: "auth_sessions_replaced_by_session_id_key") @map("replaced_by_session_id") @db.Uuid
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz(6)
  lastSeenAt          DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  rotatedAt           DateTime? @map("rotated_at") @db.Timestamptz(6)
  revokedAt           DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  replacedBy   AuthSession? @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  replaces     AuthSession? @relation("SessionRotation")

  @@index([userId, expiresAt], map: "auth_sessions_user_expires_idx")
  @@index([organizationId, userId, expiresAt], map: "auth_sessions_org_user_expires_idx")
  @@index([familyId], map: "auth_sessions_family_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model OrganizationMembership {
  id             String           @id @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userId], map: "organization_memberships_org_user_key")
  @@index([userId], map: "organization_memberships_user_id_idx")
  @@index([organizationId, role], map: "organization_memberships_org_role_idx")
  @@map("organization_memberships")
}

model TranslationRevision {
  id                       String   @id @db.Uuid
  dialogueTranslationId    String   @map("dialogue_translation_id") @db.Uuid
  trackId                  String   @map("track_id") @db.Uuid
  workspaceId              String   @map("workspace_id") @db.Uuid
  organizationId           String   @map("organization_id") @db.Uuid
  projectId                String   @map("project_id") @db.Uuid
  localizedDialogueId      String   @map("localized_dialogue_id") @db.Uuid
  sourceDialogueRevisionId String   @map("source_dialogue_revision_id") @db.Uuid
  generationId             String?  @map("generation_id") @db.Uuid
  revisionNumber           Int      @map("revision_number")
  translatedText           String   @map("translated_text") @db.Text
  createdByUserId          String   @map("created_by_user_id") @db.Uuid
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  dialogueTranslation DialogueTranslation    @relation(fields: [dialogueTranslationId, trackId, workspaceId, organizationId, projectId], references: [id, trackId, workspaceId, organizationId, projectId], onDelete: Restrict)
  sourceRevision      SourceDialogueRevision @relation(fields: [sourceDialogueRevisionId, localizedDialogueId, workspaceId, organizationId, projectId], references: [id, localizedDialogueId, workspaceId, organizationId, projectId], onDelete: Restrict)
  generation          TranslationGeneration? @relation(fields: [generationId, trackId, workspaceId, organizationId, projectId], references: [id, trackId, workspaceId, organizationId, projectId], onDelete: Restrict)
  createdByMembership OrganizationMembership @relation("TranslationRevisionCreator", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict)
  selectedBy          TranslationSelection?  @relation("SelectedTranslationRevision")

  @@unique([dialogueTranslationId, revisionNumber], map: "translation_revisions_translation_revision_key")
  @@unique([id, dialogueTranslationId, trackId, workspaceId, organizationId, projectId], map: "translation_revisions_id_translation_tenant_key")
  @@index([organizationId, projectId, dialogueTranslationId, revisionNumber(sort: Desc), id(sort: Desc)], map: "translation_revisions_tenant_history_idx")
  @@index([sourceDialogueRevisionId, localizedDialogueId, workspaceId, organizationId, projectId], map: "translation_revisions_source_revision_idx")
  @@index([generationId, trackId, workspaceId, organizationId, projectId], map: "translation_revisions_generation_idx")
  @@index([organizationId, createdByUserId], map: "translation_revisions_creator_idx")
  @@map("translation_revisions")
}

model TranslationSelection {
  dialogueTranslationId String                 @map("dialogue_translation_id") @db.Uuid
  trackId               String                 @map("track_id") @db.Uuid
  workspaceId           String                 @map("workspace_id") @db.Uuid
  organizationId        String                 @map("organization_id") @db.Uuid
  projectId             String                 @map("project_id") @db.Uuid
  selectedRevisionId    String                 @map("selected_revision_id") @db.Uuid
  editorState           TranslationEditorState @default(DRAFT) @map("editor_state")
  revision              Int                    @default(1)
  updatedByUserId       String                 @map("updated_by_user_id") @db.Uuid
  selectedAt            DateTime               @default(now()) @map("selected_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  dialogueTranslation DialogueTranslation    @relation(fields: [dialogueTranslationId, trackId, workspaceId, organizationId, projectId], references: [id, trackId, workspaceId, organizationId, projectId], onDelete: Cascade)
  selectedRevision    TranslationRevision    @relation("SelectedTranslationRevision", fields: [selectedRevisionId, dialogueTranslationId, trackId, workspaceId, organizationId, projectId], references: [id, dialogueTranslationId, trackId, workspaceId, organizationId, projectId], onDelete: Restrict)
  updatedByMembership OrganizationMembership @relation("TranslationSelectionUpdater", fields: [organizationId, updatedByUserId], references: [organizationId, userId], onDelete: Restrict)

  @@id([dialogueTranslationId, organizationId, projectId])
  @@unique([dialogueTranslationId, trackId, workspaceId, organizationId, projectId], map: "translation_selections_translation_key")
  @@unique([selectedRevisionId, dialogueTranslationId, trackId, workspaceId, organizationId, projectId], map: "translation_selections_revision_key")
  @@index([organizationId, projectId, trackId, editorState, updatedAt, dialogueTranslationId], map: "translation_selections_editor_queue_idx")
  @@index([organizationId, updatedByUserId], map: "translation_selections_updater_idx")
  @@map("translation_selections")
}


# Copy this file to .env for local development. Never commit real credentials.
NODE_ENV=development
APP_VERSION=development
API_DOCS_ENABLED=true

# Public services
WEB_PORT=3000
API_HOST=0.0.0.0
API_PORT=3001
WORKER_HOST=0.0.0.0
WORKER_PORT=3002
AI_HOST=0.0.0.0
AI_PORT=8000
WEB_ORIGIN=http://localhost:3000
# This is embedded into the browser bundle at build time. Vercel production and
# preview deployments should normally point at their environment-specific API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/v1

# Supabase Auth. The publishable key is safe for the browser; secret/service-role
# keys are deliberately absent because normal VoiceVerse requests never need them.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_local_publishable_key
SUPABASE_URL=http://localhost:54321
SUPABASE_JWKS_URL=http://localhost:54321/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated

# Local-only infrastructure credentials. Production values come from a secrets manager.
POSTGRES_DB=voiceverse
POSTGRES_USER=voiceverse
POSTGRES_PASSWORD=voiceverse_local_only
POSTGRES_PORT=5432
# Runtime traffic. On Supabase use the direct endpoint from an IPv6-capable
# container platform, or Supavisor session mode (port 5432) on IPv4-only hosts.
DATABASE_URL=postgresql://voiceverse:voiceverse_local_only@localhost:5432/voiceverse
# Prisma CLI migrations use this independently from the runtime pool. In CI,
# use a migration role through the direct endpoint or Supavisor session mode;
# never use the transaction-mode endpoint for schema migrations.
DIRECT_URL=postgresql://voiceverse:voiceverse_local_only@localhost:5432/voiceverse
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=30000
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# S3-compatible local development storage
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
S3_REGION=us-east-1
S3_BUCKET=voiceverse-local
S3_ACCESS_KEY=voiceverse_local
S3_SECRET_KEY=voiceverse_local_only
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900
S3_MULTIPART_EXPIRY_HOURS=24
S3_PART_SIZE_BYTES=67108864
S3_SSE_ALGORITHM=none
S3_KMS_KEY_ID=
UPLOAD_MAX_BYTES=21474836480

# Durable outbox and isolated malware worker
CLAMAV_PLATFORM=linux/amd64
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_LEASE_SECONDS=30
WORKER_CONCURRENCY=2
MEDIA_PROCESSING_CONCURRENCY=1
MEDIA_EXECUTOR_BASE_URL=http://localhost:8000
# Local-only shared secret. Native worker and AI processes must use the same value;
# Compose derives the worker credential from AI_INTERNAL_BEARER_TOKEN. Production
# injects one random, rotated value into only those two workloads through a secrets manager.
AI_INTERNAL_BEARER_TOKEN=voiceverse-local-media-executor-token
MEDIA_EXECUTOR_BEARER_TOKEN=voiceverse-local-media-executor-token
MEDIA_EXECUTOR_TIMEOUT_MS=21600000
WORKFLOW_ATTEMPT_LEASE_SECONDS=300

# M5 speech analysis is fail-closed. Keep disabled until separate production
# provider images, exact model revisions, GPU capacity, and model licenses are approved.
SPEECH_ANALYSIS_ENABLED=false
VOCAL_SEPARATION_EXECUTOR_BASE_URL=http://localhost:8000
TRANSCRIPTION_EXECUTOR_BASE_URL=http://localhost:8000
DIARIZATION_EXECUTOR_BASE_URL=http://localhost:8000
SPEECH_EXECUTOR_BEARER_TOKEN=voiceverse-local-media-executor-token
# Required and validated when SPEECH_ANALYSIS_ENABLED=true. Values must match
# the immutable provider descriptors baked into the activated capability images.
VOCAL_SEPARATION_PROVIDER_NAME=activation-required
VOCAL_SEPARATION_MODEL_ID=activation-required
VOCAL_SEPARATION_MODEL_REVISION=activation-required
VOCAL_SEPARATION_RUNTIME_VERSION=activation-required
TRANSCRIPTION_PROVIDER_NAME=activation-required
TRANSCRIPTION_MODEL_ID=activation-required
TRANSCRIPTION_MODEL_REVISION=activation-required
TRANSCRIPTION_RUNTIME_VERSION=activation-required
DIARIZATION_PROVIDER_NAME=activation-required
DIARIZATION_MODEL_ID=activation-required
DIARIZATION_MODEL_REVISION=activation-required
DIARIZATION_RUNTIME_VERSION=activation-required
VOCAL_SEPARATION_EXECUTOR_TIMEOUT_MS=21600000
TRANSCRIPTION_EXECUTOR_TIMEOUT_MS=21600000
DIARIZATION_EXECUTOR_TIMEOUT_MS=21600000
VOCAL_SEPARATION_CONCURRENCY=1
TRANSCRIPTION_CONCURRENCY=1
DIARIZATION_CONCURRENCY=1
CHARACTER_IDENTIFICATION_CONCURRENCY=2
SPEECH_MANIFEST_MAX_BYTES=67108864
# Process-local sum of manifest source bytes allowed in buffering/parsing at once.
# Keep this at or above the per-object limit and size it against the worker heap;
# schema parsing can temporarily require multiple times the source JSON size.
SPEECH_MANIFEST_MEMORY_BUDGET_BYTES=67108864
SPEECH_COMPLETION_TRANSACTION_TIMEOUT_MS=300000

# M6 contextual translation is fail-closed. The stock AI image has only a
# deterministic test provider, which the AI service rejects outside ENVIRONMENT=test.
TRANSLATION_ENABLED=false
TRANSLATION_EXECUTOR_BASE_URL=http://localhost:8000
TRANSLATION_EXECUTOR_BEARER_TOKEN=voiceverse-local-media-executor-token
TRANSLATION_EXECUTOR_TIMEOUT_MS=300000
TRANSLATION_PROVIDER_NAME=activation-required
TRANSLATION_MODEL_ID=activation-required
TRANSLATION_MODEL_REVISION=activation-required
TRANSLATION_RUNTIME_VERSION=activation-required
TRANSLATION_PROMPT_VERSION=activation-required
TRANSLATION_CONCURRENCY=2
TRANSLATION_GENERATION_LEASE_SECONDS=300
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_CONNECT_TIMEOUT_MS=5000
CLAMAV_SCAN_TIMEOUT_MS=1800000
CLAMAV_CHUNK_BYTES=1048576
MEDIA_SCAN_LEASE_SECONDS=300

# CPU media-executor limits. Use disk-backed ephemeral storage, not memory-backed /tmp,
# for feature-length source media.
AI_MEDIA_SCRATCH_ROOT=/var/lib/voiceverse-media
AI_MEDIA_MAX_INPUT_BYTES=21474836480
AI_MEDIA_MAX_OUTPUT_BYTES=21474836480
AI_MEDIA_MAX_DURATION_SECONDS=21600
AI_MEDIA_PROBE_TIMEOUT_SECONDS=60
AI_MEDIA_TRANSCODE_TIMEOUT_SECONDS=7200
AI_MEDIA_SUBPROCESS_OUTPUT_LIMIT_BYTES=131072
AI_MEDIA_FFMPEG_THREADS=4

# Provider-neutral speech executor limits. The base image intentionally has no
# Whisper, Pyannote, separator, Torch, CUDA, or model weights.
AI_SPEECH_VOCAL_SEPARATION_ENABLED=false
AI_SPEECH_TRANSCRIPTION_ENABLED=false
AI_SPEECH_DIARIZATION_ENABLED=false
AI_SPEECH_SCRATCH_ROOT=/var/lib/voiceverse-speech
AI_SPEECH_MAX_INPUT_BYTES=21474836480
AI_SPEECH_MAX_OUTPUT_BYTES=21474836480
AI_SPEECH_MAX_MANIFEST_BYTES=67108864
AI_SPEECH_MAX_REQUEST_BODY_BYTES=65536
AI_SPEECH_MAX_DURATION_SECONDS=21600
AI_SPEECH_MAX_CONCURRENCY=1
AI_SPEECH_VOCAL_SEPARATION_TIMEOUT_SECONDS=21000
AI_SPEECH_TRANSCRIPTION_TIMEOUT_SECONDS=21000
AI_SPEECH_DIARIZATION_TIMEOUT_SECONDS=21000
AI_SPEECH_TIMELINE_TOLERANCE_US=50000

# Provider-neutral M6 executor. `deterministic` is test-only and rejected in
# development/production, so local application stacks keep this disabled.
AI_TRANSLATION_ENABLED=false
AI_TRANSLATION_PROVIDER=none
AI_TRANSLATION_MODEL_ID=voiceverse/deterministic-translation
AI_TRANSLATION_MODEL_REVISION=test-v1
AI_TRANSLATION_RUNTIME_VERSION=1.0.0
AI_TRANSLATION_MAX_REQUEST_BODY_BYTES=1048576
AI_TRANSLATION_PROVIDER_TIMEOUT_SECONDS=120
AI_TRANSLATION_MAX_CONCURRENCY=4
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# Observability
LOG_LEVEL=info
OTEL_SERVICE_NAMESPACE=voiceverse
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=none

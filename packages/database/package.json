{
  "name": "@voiceverse/database",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "generate": "prisma generate",
    "lint": "eslint src --max-warnings=0",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:diff": "prisma migrate diff --from-config-datasource --to-schema prisma --exit-code",
    "migrate:dev": "prisma migrate dev",
    "migrate:rehearse:m5": "bash scripts/rehearse-m5-upgrade.sh",
    "migrate:rehearse:m6": "bash scripts/rehearse-m6-upgrade.sh",
    "migrate:status": "prisma migrate status",
    "studio": "prisma studio",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "globals": "17.7.0",
    "prisma": "7.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}

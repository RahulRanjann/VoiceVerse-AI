  workspaceId           String                      @map("workspace_id") @db.Uuid
  trackId               String                      @map("track_id") @db.Uuid
  sceneId               String                      @map("scene_id") @db.Uuid
  createdByUserId       String                      @map("created_by_user_id") @db.Uuid
  idempotencyKey        String                      @map("idempotency_key") @db.VarChar(128)
  status                TranslationGenerationStatus @default(QUEUED)
  attemptCount          Int                         @default(0) @map("attempt_count")
  maxAttempts           Int                         @default(3) @map("max_attempts")
  leaseToken            String?                     @map("lease_token") @db.Uuid
  leasedUntil           DateTime?                   @map("leased_until") @db.Timestamptz(6)
  heartbeatAt           DateTime?                   @map("heartbeat_at") @db.Timestamptz(6)
  executionId           String?                     @unique(map: "translation_generations_execution_id_key") @map("execution_id") @db.Uuid
  providerName          String                      @map("provider_name") @db.VarChar(100)
  modelId               String                      @map("model_id") @db.VarChar(160)
  modelRevision         String                      @map("model_revision") @db.VarChar(160)
  runtimeVersion        String                      @map("runtime_version") @db.VarChar(100)
  promptVersion         String                      @map("prompt_version") @db.VarChar(100)
  configurationSnapshot Json                        @map("configuration_snapshot") @db.JsonB
  configurationHash     String                      @map("configuration_hash") @db.Char(64)
  inputSnapshot         Json                        @map("input_snapshot") @db.JsonB
  inputRevisionHash     String                      @map("input_revision_hash") @db.Char(64)
  contextSnapshot       Json                        @map("context_snapshot") @db.JsonB
  contextSnapshotHash   String                      @map("context_snapshot_hash") @db.Char(64)
  errorCode             String?                     @map("error_code") @db.VarChar(100)
  errorDetail           String?                     @map("error_detail") @db.Text
  queuedAt              DateTime                    @default(now()) @map("queued_at") @db.Timestamptz(6)
  startedAt             DateTime?                   @map("started_at") @db.Timestamptz(6)
  completedAt           DateTime?                   @map("completed_at") @db.Timestamptz(6)
  createdAt             DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace            LocalizationWorkspace  @relation(fields: [workspaceId, organizationId, projectId], references: [id, organizationId, projectId], onDelete: Cascade)
  track                LocalizationTrack      @relation(fields: [trackId, workspaceId, organizationId, projectId], references: [id, workspaceId, organizationId, projectId], onDelete: Cascade)
  scene                LocalizationScene      @relation(fields: [sceneId, workspaceId, organizationId, projectId], references: [id, workspaceId, organizationId, projectId], onDelete: Restrict)
  createdByMembership  OrganizationMembership @relation("TranslationGenerationCreator", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict)
  translationRevisions TranslationRevision[]

  @@unique([trackId, idempotencyKey], map: "translation_generations_track_idempotency_key")
  @@unique([id, trackId, workspaceId, organizationId, projectId], map: "translation_generations_id_track_tenant_key")
  @@index([status, leasedUntil, id], map: "translation_generations_status_lease_idx")
  @@index([trackId, createdAt(sort: Desc), id(sort: Desc)], map: "translation_generations_track_created_idx")
  @@index([sceneId, createdAt(sort: Desc), id(sort: Desc)], map: "translation_generations_scene_created_idx")
  @@index([workspaceId, organizationId, projectId], map: "translation_generations_workspace_idx")
  @@index([organizationId, projectId, status, queuedAt, id], map: "translation_generations_tenant_queue_idx")
  @@index([organizationId, createdByUserId], map: "translation_generations_creator_idx")
  @@map("translation_generations")
}

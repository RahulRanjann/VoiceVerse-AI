{
  "name": "@voiceverse/api",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "dev:worker": "nest start --watch --entryFile worker",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1088.0",
    "@aws-sdk/s3-request-presigner": "3.1088.0",
    "@fastify/compress": "9.0.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/static": "9.1.3",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/throttler": "6.5.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/sdk-node": "0.220.0",
    "@supabase/server": "1.4.0",
    "@supabase/supabase-js": "2.110.6",
    "@voiceverse/database": "workspace:*",
    "bullmq": "5.80.5",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "fastify": "5.10.0",
    "ioredis": "5.11.1",
    "jose": "6.2.3",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@nestjs/cli": "11.0.24",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.28",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^9.39.5",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}

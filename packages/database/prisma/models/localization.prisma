enum TranslationEditorState {
  DRAFT     @map("draft")
  IN_REVIEW @map("in_review")
  APPROVED  @map("approved")

  @@map("translation_editor_state")
}

enum TranslationGenerationStatus {
  QUEUED    @map("queued")
  RUNNING   @map("running")
  SUCCEEDED @map("succeeded")
  FAILED    @map("failed")

  @@map("translation_generation_status")
}

model LocalizationWorkspace {
  id               String   @id @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  speechAnalysisId String   @map("speech_analysis_id") @db.Uuid
  createdByUserId  String   @map("created_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization        Organization                   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project             Project                        @relation(fields: [projectId, organizationId], references: [id, organizationId], onDelete: Restrict)
  speechAnalysis      SpeechAnalysis                 @relation(fields: [speechAnalysisId, organizationId, projectId], references: [id, organizationId, projectId], onDelete: Restrict, onUpdate: Restrict, map: "localization_workspaces_speech_analysis_fkey")
  committedSelection  ProjectSpeechAnalysisSelection @relation(fields: [speechAnalysisId, organizationId, projectId], references: [speechAnalysisId, organizationId, projectId], onDelete: Restrict, onUpdate: Restrict, map: "localization_workspaces_committed_selection_fkey")
  createdByMembership OrganizationMembership         @relation("LocalizationWorkspaceCreator", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict)
  tracks              LocalizationTrack[]
  scenes              LocalizationScene[]
  dialogues           LocalizedDialogue[]
  generations         TranslationGeneration[]

  @@unique([organizationId, projectId], map: "localization_workspaces_org_project_key")
  @@unique([speechAnalysisId, organizationId, projectId], map: "localization_workspaces_analysis_tenant_key")
  @@unique([id, organizationId, projectId], map: "localization_workspaces_id_tenant_key")
  @@unique([id, speechAnalysisId, organizationId, projectId], map: "localization_workspaces_id_analysis_tenant_key")
  @@index([projectId, organizationId], map: "localization_workspaces_project_tenant_idx")
  @@index([organizationId, createdByUserId], map: "localization_workspaces_creator_idx")
  @@map("localization_workspaces")
}

model LocalizationTrack {
  id               String   @id @db.Uuid
  workspaceId      String   @map("workspace_id") @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  targetLanguageId String   @map("target_language_id") @db.Uuid
  createdByUserId  String   @map("created_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace           LocalizationWorkspace   @relation(fields: [workspaceId, organizationId, projectId], references: [id, organizationId, projectId], onDelete: Cascade)
  targetLanguage      ProjectTargetLanguage   @relation(fields: [projectId, targetLanguageId], references: [projectId, languageId], onDelete: Restrict)
  createdByMembership OrganizationMembership  @relation("LocalizationTrackCreator", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict)
  translations        DialogueTranslation[]
  glossaryEntries     GlossaryEntry[]
  generations         TranslationGeneration[]

  @@unique([workspaceId, targetLanguageId], map: "localization_tracks_workspace_language_key")
  @@unique([id, workspaceId, organizationId, projectId], map: "localization_tracks_id_workspace_tenant_key")
  @@index([organizationId, projectId, createdAt, id], map: "localization_tracks_tenant_created_idx")
  @@index([projectId, targetLanguageId], map: "localization_tracks_project_language_idx")
  @@index([organizationId, createdByUserId], map: "localization_tracks_creator_idx")
  @@map("localization_tracks")
}

model LocalizationScene {
  id              String   @id @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  ordinal         Int
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace           LocalizationWorkspace       @relation(fields: [workspaceId, organizationId, projectId], references: [id, organizationId, projectId], onDelete: Cascade)
  createdByMembership OrganizationMembership      @relation("LocalizationSceneCreator", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict)
  revisions           LocalizationSceneRevision[]
  selection           LocalizationSceneSelection?
  dialogues           LocalizedDialogue[]
  generations         TranslationGeneration[]

  @@unique([workspaceId, ordinal], map: "localization_scenes_workspace_ordinal_key")
  @@unique([id, workspaceId, organizationId, projectId], map: "localization_scenes_id_workspace_tenant_key")
  @@index([organizationId, projectId, workspaceId, ordinal, id], map: "localization_scenes_tenant_timeline_idx")
  @@index([organizationId, createdByUserId], map: "localization_scenes_creator_idx")
  @@map("localization_scenes")
}

model LocalizationSceneRevision {
  id              String   @id @db.Uuid
  sceneId         String   @map("scene_id") @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  revisionNumber  Int      @map("revision_number")
  startTimeUs     BigInt   @map("start_time_us")
  endTimeUs       BigInt   @map("end_time_us")
  title           String?  @db.VarChar(200)
  summary         String?  @db.VarChar(4000)
  culturalContext String?  @map("cultural_context") @db.VarChar(8000)
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  scene               LocalizationScene           @relation(fields: [sceneId, workspaceId, organizationId, projectId], references: [id, workspaceId, organizationId, projectId], onDelete: Restrict)
  createdByMembership OrganizationMembership      @relation("LocalizationSceneRevisionCreator", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict)
  selectedBy          LocalizationSceneSelection? @relation("SelectedLocalizationSceneRevision")

  @@unique([sceneId, revisionNumber], map: "localization_scene_revisions_scene_revision_key")
  @@unique([id, sceneId, workspaceId, organizationId, projectId], map: "localization_scene_revisions_id_scene_tenant_key")
  @@index([organizationId, projectId, sceneId, revisionNumber(sort: Desc), id(sort: Desc)], map: "localization_scene_revisions_tenant_history_idx")
  @@index([organizationId, createdByUserId], map: "localization_scene_revisions_creator_idx")
  @@map("localization_scene_revisions")
}

model LocalizationSceneSelection {
  sceneId            String   @map("scene_id") @db.Uuid
  workspaceId        String   @map("workspace_id") @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  projectId          String   @map("project_id") @db.Uuid
  selectedRevisionId String   @map("selected_revision_id") @db.Uuid
  revision           Int      @default(1)
  updatedByUserId    String   @map("updated_by_user_id") @db.Uuid
  selectedAt         DateTime @default(now()) @map("selected_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  scene               LocalizationScene         @relation(fields: [sceneId, workspaceId, organizationId, projectId], references: [id, workspaceId, organizationId, projectId], onDelete: Cascade)
  selectedRevision    LocalizationSceneRevision @relation("SelectedLocalizationSceneRevision", fields: [selectedRevisionId, sceneId, workspaceId, organizationId, projectId], references: [id, sceneId, workspaceId, organizationId, projectId], onDelete: Restrict)
  updatedByMembership OrganizationMembership    @relation("LocalizationSceneSelectionUpdater", fields: [organizationId, updatedByUserId], references: [organizationId, userId], onDelete: Restrict)

  @@id([sceneId, organizationId, projectId])
  @@unique([sceneId, workspaceId, organizationId, projectId], map: "localization_scene_selections_scene_key")
  @@unique([selectedRevisionId, sceneId, workspaceId, organizationId, projectId], map: "localization_scene_selections_revision_key")
  @@index([organizationId, updatedByUserId], map: "localization_scene_selections_updater_idx")
  @@map("localization_scene_selections")
}

model LocalizedDialogue {
  id                String   @id @db.Uuid
  workspaceId       String   @map("workspace_id") @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  speechAnalysisId  String   @map("speech_analysis_id") @db.Uuid
  sceneId           String   @map("scene_id") @db.Uuid
  dialogueSegmentId String   @map("dialogue_segment_id") @db.Uuid
  sequenceNumber    Int      @map("sequence_number")
  startTimeUs       BigInt   @map("start_time_us")
  endTimeUs         BigInt   @map("end_time_us")
  createdByUserId   String   @map("created_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace           LocalizationWorkspace    @relation(fields: [workspaceId, speechAnalysisId, organizationId, projectId], references: [id, speechAnalysisId, organizationId, projectId], onDelete: Cascade)
  scene               LocalizationScene        @relation(fields: [sceneId, workspaceId, organizationId, projectId], references: [id, workspaceId, organizationId, projectId], onDelete: Restrict)
  dialogueSegment     DialogueSegment          @relation(fields: [dialogueSegmentId, speechAnalysisId], references: [id, speechAnalysisId], onDelete: Restrict)
  createdByMembership OrganizationMembership   @relation("LocalizedDialogueCreator", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict)
  sourceRevisions     SourceDialogueRevision[]
  sourceSelection     SourceDialogueSelection?
  translations        DialogueTranslation[]

  @@unique([workspaceId, dialogueSegmentId], map: "localized_dialogues_workspace_segment_key")
  @@unique([workspaceId, sequenceNumber], map: "localized_dialogues_workspace_sequence_key")
  @@unique([id, workspaceId, organizationId, projectId], map: "localized_dialogues_id_workspace_tenant_key")
  @@index([organizationId, projectId, sceneId, startTimeUs, id], map: "localized_dialogues_tenant_scene_timeline_idx")
  @@index([dialogueSegmentId, speechAnalysisId], map: "localized_dialogues_source_segment_idx")
  @@index([organizationId, createdByUserId], map: "localized_dialogues_creator_idx")
  @@map("localized_dialogues")
}


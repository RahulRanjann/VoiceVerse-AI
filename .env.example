# Copy this file to .env for local development. Never commit real credentials.
NODE_ENV=development

# Public services
WEB_PORT=3000
API_HOST=0.0.0.0
API_PORT=3001
WORKER_HOST=0.0.0.0
WORKER_PORT=3002
AI_HOST=0.0.0.0
AI_PORT=8000
WEB_ORIGIN=http://localhost:3000
WEB_AUTH_SUCCESS_URL=http://localhost:3000

# Browser authentication. JWT keys are base64-encoded Ed25519 PKCS8/SPKI values
# in PEM or DER form. The transaction key must decode to exactly 32 random bytes.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_JWT_ISSUER=voiceverse-api
AUTH_JWT_AUDIENCE=voiceverse-web
AUTH_JWT_PRIVATE_KEY_BASE64=
AUTH_JWT_PUBLIC_KEY_BASE64=
AUTH_TRANSACTION_ENCRYPTION_KEY_BASE64=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/google/callback

# Local-only infrastructure credentials. Production values come from a secrets manager.
POSTGRES_DB=voiceverse
POSTGRES_USER=voiceverse
POSTGRES_PASSWORD=voiceverse_local_only
POSTGRES_PORT=5432
DATABASE_URL=postgresql://voiceverse:voiceverse_local_only@localhost:5432/voiceverse
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# S3-compatible local development storage
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_BUCKET=voiceverse-local
S3_ACCESS_KEY=voiceverse_local
S3_SECRET_KEY=voiceverse_local_only
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900
S3_MULTIPART_EXPIRY_HOURS=24
S3_PART_SIZE_BYTES=67108864
S3_SSE_ALGORITHM=none
S3_KMS_KEY_ID=
UPLOAD_MAX_BYTES=21474836480

# Durable outbox and isolated malware worker
CLAMAV_PLATFORM=linux/amd64
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_LEASE_SECONDS=30
WORKER_CONCURRENCY=2
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_CONNECT_TIMEOUT_MS=5000
CLAMAV_SCAN_TIMEOUT_MS=1800000
CLAMAV_CHUNK_BYTES=1048576

# Observability
LOG_LEVEL=info
OTEL_SERVICE_NAMESPACE=voiceverse
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=none
